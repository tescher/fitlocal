ANTHROPIC_API_KEY=your_key_here

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Set to true when running behind HTTPS (Opalstack / any reverse proxy with SSL)
HTTPS=true

# Port the app listens on (Opalstack assigns this; gunicorn reads it)
PORT=5000

# Set to true only if you want to allow new user registration
ALLOW_REGISTRATION=false

# Optional: Google OAuth (leave blank to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
